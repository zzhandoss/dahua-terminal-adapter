NODE_ENV=development
LOG_LEVEL=info
LOG_PRETTY=true

HOST=0.0.0.0
PORT=8091
BASE_URL=http://127.0.0.1:8091

VENDOR_KEY=dahua
ADAPTER_INSTANCE_KEY=dahua-primary
ADAPTER_INSTANCE_NAME=Dahua Adapter
ADAPTER_VERSION=1.0.0
RETENTION_MS=604800000

DS_BASE_URL=http://127.0.0.1:3000
DS_BEARER_TOKEN=replace_me
DS_HMAC_SECRET=replace_me
BACKFILL_BEARER_TOKEN=replace_me
PUSH_DIGEST_REALM=dahua-adapter
PUSH_DIGEST_NONCE_TTL_MS=300000

SQLITE_PATH=./data/dahua-adapter.db
HEARTBEAT_INTERVAL_MS=10000
DELIVERY_INTERVAL_MS=1500
PURGE_INTERVAL_MS=60000
DEVICE_RECONNECT_DELAY_MS=3000
HTTP_TIMEOUT_MS=10000
REJECT_UNAUTHORIZED=false

MOCK_ENABLED=false
MOCK_EVENT_BURST_INTERVAL_MS=30000
MOCK_EVENT_INTRA_INTERVAL_MS=2000
MOCK_EVENT_BURST_MIN=2
MOCK_EVENT_BURST_MAX=3
