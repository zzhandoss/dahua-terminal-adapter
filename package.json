{
  "name": "dahua-adapter",
  "version": "0.1.2",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run",
    "dev": "pnpm run build && node dist/src/index.js",
    "release:verify-version": "node scripts/release/verify-version.mjs",
    "release:package-source": "node scripts/release/package-source.mjs",
    "release:package-build": "node scripts/release/package-build.mjs",
    "release:checksums": "node scripts/release/write-checksums.mjs"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.4",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.4",
    "fastify": "^5.7.4",
    "pino": "^10.3.1",
    "undici": "^7.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^10.0.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
